{
	"hosting": {
		"public": "frontend/dist",
		"ignore": [
			"firebase.json",
			"**/.*",
			"**/node_modules/**"
		],
		"rewrites": [
			{
				"source": "**",
				"destination": "/index.html"
			}
		]
	},
	"functions": {
		"source": "backend"
	},
	"firestore": {
		"rules": "firestore.rules"
	},
	"storage": {
		"rules": "storage.rules"
	},
	"emulators": {
		"ui": {
			"enabled": true,
			"host": "127.0.0.1",
			"port": 4000
		},
		"auth": {
			"host": "127.0.0.1",
			"port": 9099
		},
		"firestore": {
			"host": "127.0.0.1",
			"port": 8080
		},
		"storage": {
			"host": "127.0.0.1",
			"port": 9199
		},
		"functions": {
			"host": "127.0.0.1",
			"port": 5001
		}
	}
}